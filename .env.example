# ================================
# TruthLens AI — Environment Variables
# ================================

# MongoDB Connection
# Get from: https://cloud.mongodb.com (free tier works)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/truthlens?retryWrites=true&w=majority

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Wikipedia API (no key needed — public endpoint)
WIKIPEDIA_API_URL=https://en.wikipedia.org/w/api.php

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Google Search API for deeper fact-checking
# Get from: https://developers.google.com/custom-search/v1/introduction
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_CX=your_custom_search_engine_id
